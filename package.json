{
  "name": "claude-glance",
  "version": "0.0.1",
  "description": "Read-only macOS dashboard for monitoring active Claude Code sessions at a glance.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/Priyans-hu/claude-glance",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Priyans-hu/claude-glance.git"
  },
  "bugs": {
    "url": "https://github.com/Priyans-hu/claude-glance/issues"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "lucide-svelte": "^1.0.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.0"
  }
}
